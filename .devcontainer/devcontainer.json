{
  "name": "BuzzCircle Dev",
  "dockerComposeFile": "docker-compose.yml",
  "service": "buzzcircle",
  "workspaceFolder": "/workspace",
  "settings": {
    "terminal.integrated.defaultProfile.linux": "bash"
  },
  "extensions": [
    "vscjava.vscode-java-pack"
  ],
  "postCreateCommand": "mvn clean package -DskipTests",
  "forwardPorts": [8080],
  "remoteUser": "vscode"
}
